<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.module.category" id="module_category_calculator">
        <field name="name">Calculator</field>
        <field name="description">Helps you manage the energy calculator.</field>
        <field name="sequence">102</field>
    </record>

    <record id="module_category_union_energy_calculator" model="res.groups.privilege">
        <field name="name">Calculator</field>
        <field name="description">Helps you manage the energy calculator.</field>
        <field name="category_id" ref="module_category_calculator"/>
        <field name="sequence">1</field>
    </record>

    <record id="group_union_energy_calculator_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="module_category_union_energy_calculator"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_union_energy_calculator_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="module_category_union_energy_calculator"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        <field name="implied_ids"
               eval="[(4, ref('union_energy_calculator.group_union_energy_calculator_user'))]"/>
    </record>
</odoo>
