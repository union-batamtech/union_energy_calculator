<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_calculator_enquiry_list" model="ir.ui.view">
        <field name="name">calculator.enquiry.list</field>
        <field name="model">calculator.enquiry</field>
        <field name="arch" type="xml">
            <list string="Calculator Enquiries">
                <field name="name"/>
                <field name="contact_name"/>
                <field name="email"/>
                <field name="enquiry_type"/>
                <field name="phase_type"/>
                <field name="rooftop_surface_m2"/>
                <field name="monthly_electricity_bill"/>
                <field name="cost_efficiency_pct"/>
                <field name="monthly_savings"/>
                <field name="expected_revenue"/>
                <field name="lead_id"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="view_calculator_enquiry_form" model="ir.ui.view">
        <field name="name">calculator.enquiry.form</field>
        <field name="model">calculator.enquiry</field>
        <field name="arch" type="xml">
            <form string="Calculator Enquiry">
                <sheet>
                    <group>
                        <group string="Contact">
                            <field name="contact_name"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group string="Enquiry">
                            <field name="enquiry_type" widget="radio"/>
                            <field name="phase_type" widget="radio"/>
                        </group>
                    </group>
                    <group>
                        <group string="How to calculate?">
                            <field name="rooftop_surface_m2"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="monthly_electricity_bill"/>
                        </group>
                        <group string="Results">
                            <field name="estimated_kwh"/>
                            <field name="solar_yield_kwh"/>
                            <field name="cost_efficiency_pct"/>
                            <field name="monthly_savings"/>
                            <field name="expected_revenue"/>
                            <field name="estimated_price"/>
                            <field name="lead_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_calculator_enquiry_search" model="ir.ui.view">
        <field name="name">calculator.enquiry.search</field>
        <field name="model">calculator.enquiry</field>
        <field name="arch" type="xml">
            <search string="Calculator Enquiries">
                <field name="name"/>
                <field name="contact_name"/>
                <field name="email"/>
                <field name="enquiry_type"/>
                <field name="phase_type"/>
                <filter string="Residential" name="residential"
                        domain="[('enquiry_type', '=', 'residential')]"/>
                <filter string="Commercial" name="commercial"
                        domain="[('enquiry_type', '=', 'commercial')]"/>
                <filter string="Single Phase" name="single_phase"
                        domain="[('phase_type', '=', 'single')]"/>
                <filter string="Three Phase" name="three_phase"
                        domain="[('phase_type', '=', 'three')]"/>
            </search>
        </field>
    </record>

    <record id="action_calculator_enquiry" model="ir.actions.act_window">
        <field name="name">Calculator Enquiries</field>
        <field name="res_model">calculator.enquiry</field>
        <field name="path">calculator-enquiries</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_calculator_enquiry_search"/>
    </record>
</odoo>
