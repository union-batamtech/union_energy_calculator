<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== PARTIALS ==================== -->

    <template id="calculator_hero" name="Calculator Hero">
        <header class="o_calc_hero">
            <div class="container">
                <h1 class="o_calc_hero__title">Solar Savings Calculator</h1>
                <p class="o_calc_hero__subtitle">
                    Tell us about your property in a few steps — your personalised solar estimate
                    appears after you submit your enquiry.
                </p>
            </div>
        </header>
    </template>

    <template id="calculator_progress" name="Calculator Progress">
        <nav class="o_calc_progress" aria-label="Calculator steps">
            <div class="o_calc_progress__step o_calc_progress__step--active" data-progress-step="1">
                <span class="o_calc_progress__num">1</span>
                <span class="o_calc_progress__label">Type</span>
            </div>
            <div class="o_calc_progress__connector" aria-hidden="true"/>
            <div class="o_calc_progress__step" data-progress-step="2">
                <span class="o_calc_progress__num">2</span>
                <span class="o_calc_progress__label">Property</span>
            </div>
            <div class="o_calc_progress__connector" aria-hidden="true"/>
            <div class="o_calc_progress__step" data-progress-step="3">
                <span class="o_calc_progress__num">3</span>
                <span class="o_calc_progress__label">Phase</span>
            </div>
            <div class="o_calc_progress__connector" aria-hidden="true"/>
            <div class="o_calc_progress__step" data-progress-step="4">
                <span class="o_calc_progress__num">4</span>
                <span class="o_calc_progress__label">Contact</span>
            </div>
        </nav>
    </template>

    <template id="calculator_section_enquiry_type" name="Calculator Enquiry Type">
        <div class="o_calc_section">
            <h2 class="o_calc_section__title">I am enquiring for</h2>
            <div class="o_calc_segments" role="group" aria-label="Enquiry type">
                <label class="o_calc_segment o_calc_segment--active">
                    <input type="radio" name="enquiry_type" value="residential" checked="checked"/>
                    <span class="o_calc_segment__icon" aria-hidden="true">🏠</span>
                    <span class="o_calc_segment__label">Residential</span>
                    <span class="o_calc_segment__hint">Home &amp; landed</span>
                </label>
                <label class="o_calc_segment">
                    <input type="radio" name="enquiry_type" value="commercial"/>
                    <span class="o_calc_segment__icon" aria-hidden="true">🏢</span>
                    <span class="o_calc_segment__label">Commercial</span>
                    <span class="o_calc_segment__hint">Business premises</span>
                </label>
            </div>
        </div>
    </template>

    <template id="calculator_section_property" name="Calculator Property">
        <div class="o_calc_section">
            <h2 class="o_calc_section__title">Your property</h2>
            <div class="o_calc_slider-group">
                <div class="o_calc_slider-header">
                    <label for="rooftop_surface_m2_range">Rooftop surface</label>
                    <span class="o_calc_slider-value">
                        <span id="rooftop_surface_m2_display">80</span> m²
                    </span>
                </div>
                <input type="range" class="o_calc_range" id="rooftop_surface_m2_range"
                       min="10" max="500" step="1" value="80"
                       aria-valuemin="10" aria-valuemax="500" aria-valuenow="80"/>
                <input type="hidden" name="rooftop_surface_m2" id="rooftop_surface_m2" value="80"/>
            </div>
            <div class="o_calc_slider-group">
                <div class="o_calc_slider-header">
                    <label for="monthly_electricity_bill_range">Monthly electricity bill</label>
                    <span class="o_calc_slider-value">
                        <span class="o_calc_currency_symbol" t-out="currency_symbol"/>
                        <span id="monthly_electricity_bill_display">200</span>
                    </span>
                </div>
                <input type="range" class="o_calc_range" id="monthly_electricity_bill_range"
                       min="50" max="5000" step="10" value="200"
                       aria-valuemin="50" aria-valuemax="5000" aria-valuenow="200"/>
                <input type="hidden" name="monthly_electricity_bill" id="monthly_electricity_bill" value="200"/>
            </div>
        </div>
    </template>

    <template id="calculator_section_phase" name="Calculator Phase Type">
        <div class="o_calc_section">
            <h2 class="o_calc_section__title">Phase type</h2>
            <div class="o_calc_pills" role="group" aria-label="Phase type">
                <label class="o_calc_pill o_calc_pill--active">
                    <input type="radio" name="phase_type" value="single" checked="checked"/>
                    Single Phase
                </label>
                <label class="o_calc_pill">
                    <input type="radio" name="phase_type" value="three"/>
                    Three Phase
                </label>
            </div>
        </div>
    </template>

    <template id="calculator_section_contact" name="Calculator Contact">
        <div class="o_calc_section">
            <h2 class="o_calc_section__title">Your contact details</h2>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" for="contact_name">Full name *</label>
                    <input type="text" class="form-control o_calc_input" id="contact_name"
                           name="contact_name" required="required" placeholder="John Tan"
                           autocomplete="name"/>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="email">Email *</label>
                    <input type="email" class="form-control o_calc_input" id="email"
                           name="email" required="required" placeholder="you@email.com"
                           autocomplete="email"/>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="phone">Phone *</label>
                    <input type="tel" class="form-control o_calc_input" id="phone"
                           name="phone" required="required" placeholder="+65 9123 4567"
                           autocomplete="tel"/>
                </div>
            </div>
        </div>
    </template>

    <template id="calculator_step_nav" name="Calculator Step Navigation">
        <div class="o_calc_step_nav">
            <button type="button" class="btn o_calc_btn o_calc_btn--outline o_calc_step_back d-none">
                Back
            </button>
            <div class="o_calc_step_nav__primary">
                <button type="button" class="btn o_calc_btn o_calc_btn--outline o_calc_step_next">
                    Next
                </button>
                <button type="button"
                        class="btn o_wlf_cta__btn o_calculator_submit d-none">
                    <span class="o_calculator_submit__label" style="text-transform: capitalize;">Submit Enquiry</span>
                </button>
            </div>
        </div>
    </template>

    <template id="calculator_results" name="Calculator Pricing Results">
        <div class="o_calc_pricing" id="calculator_pricing" aria-live="polite">
            <header class="o_calc_pricing__header">
                <h2 class="o_calc_pricing__title">Your solar estimate</h2>
                <p class="o_calc_pricing__lead">
                    Based on the details you shared — here is what solar could do for your property.
                </p>
            </header>

            <div class="o_calc_pricing__hero">
                <span class="o_calc_pricing__hero-label">Cost efficiency</span>
                <p class="o_calc_pricing__hero-value">
                    <span id="calculator_cost_efficiency">—</span>%
                </p>
                <p class="o_calc_pricing__hero-hint">of your consumption offset by solar</p>
            </div>

            <div class="o_calc_pricing__cards">
                <article class="o_calc_pricing__card">
                    <span class="o_calc_pricing__card-label">Est. monthly savings</span>
                    <p class="o_calc_pricing__card-value">
                        <span class="o_calc_currency_symbol" t-out="currency_symbol"/>
                        <span id="calculator_monthly_savings">—</span>
                    </p>
                </article>
                <article class="o_calc_pricing__card">
                    <span class="o_calc_pricing__card-label">Est. annual savings</span>
                    <p class="o_calc_pricing__card-value">
                        <span class="o_calc_currency_symbol" t-out="currency_symbol"/>
                        <span id="calculator_annual_savings">—</span>
                    </p>
                </article>
                <article class="o_calc_pricing__card">
                    <span class="o_calc_pricing__card-label">Est. consumption</span>
                    <p class="o_calc_pricing__card-value">
                        <span id="calculator_estimated_kwh">—</span> kWh
                    </p>
                    <span class="o_calc_pricing__card-hint">per month</span>
                </article>
                <article class="o_calc_pricing__card">
                    <span class="o_calc_pricing__card-label">Solar yield</span>
                    <p class="o_calc_pricing__card-value">
                        <span id="calculator_solar_yield_kwh">—</span> kWh
                    </p>
                    <span class="o_calc_pricing__card-hint">per month</span>
                </article>
            </div>
        </div>
    </template>

    <template id="calculator_outcome" name="Calculator Outcome">
        <div class="o_calc_card o_calc_outcome d-none" id="calculator_outcome">
            <div class="o_calc_success" id="calculator_success" role="status">
                <div class="o_calc_success__icon" aria-hidden="true">✓</div>
                <h3>Enquiry submitted!</h3>
                <p>Thank you — our team will reach out shortly with your personalised solar proposal.</p>
            </div>

            <t t-call="union_energy_calculator.calculator_results"/>

            <div class="o_calc_outcome__actions">
                <button type="button" class="btn o_wlf_cta__btn o_calc_restart">
                    <span style="text-transform: capitalize;">Start new calculation</span>
                </button>
            </div>
        </div>
    </template>

    <template id="calculator_form" name="Calculator Form">
        <div id="calculator_wizard">
            <form id="union_energy_calculator_form" class="o_calc_card" novalidate="novalidate">
                <t t-call="union_energy_calculator.calculator_progress"/>

                <div class="o_calc_steps">
                    <div class="o_calc_step" data-step="1">
                        <t t-call="union_energy_calculator.calculator_section_enquiry_type"/>
                    </div>
                    <div class="o_calc_step d-none" data-step="2">
                        <t t-call="union_energy_calculator.calculator_section_property"/>
                    </div>
                    <div class="o_calc_step d-none" data-step="3">
                        <t t-call="union_energy_calculator.calculator_section_phase"/>
                    </div>
                    <div class="o_calc_step d-none" data-step="4">
                        <t t-call="union_energy_calculator.calculator_section_contact"/>
                    </div>
                </div>

                <div class="o_calc_error alert alert-danger d-none" id="calculator_error" role="alert"/>

                <t t-call="union_energy_calculator.calculator_step_nav"/>
            </form>
        </div>
        <t t-call="union_energy_calculator.calculator_outcome"/>
    </template>

    <template id="calculator_page_content" name="Calculator Page Content">
        <section class="o_union_energy_calculator">
            <t t-call="union_energy_calculator.calculator_hero"/>
            <div class="container o_calc_body">
                <div class="row justify-content-center">
                    <div class="col-xl-10">
                        <t t-call="union_energy_calculator.calculator_form"/>
                    </div>
                </div>
            </div>
        </section>
    </template>

    <!-- ==================== PAGE (inherits website shell) ==================== -->

    <template id="calculator_page" name="Energy Calculator"
              inherit_id="union_energy_web.solar_savings_calculator_page">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="oe_structure o_wlf_solar_savings_calculator o_wlf_content_page">
                <t t-call="union_energy_calculator.calculator_page_content"/>
            </div>
        </xpath>
    </template>

</odoo>
