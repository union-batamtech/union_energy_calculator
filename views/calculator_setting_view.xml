<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_calculator_setting_form" model="ir.ui.view">
        <field name="name">calculator.setting.form</field>
        <field name="model">calculator.setting</field>
        <field name="arch" type="xml">
            <form string="Calculator Settings">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Pricing">
                            <field name="currency_id" invisible="1"/>
                            <field name="price_per_kwh"/>
                            <field name="kwh_yield_per_m2"/>
                            <field name="install_price_per_m2"/>
                            <field name="residential_multiplier"/>
                            <field name="commercial_multiplier"/>
                        </group>
                        <group string="Phase Surcharges">
                            <field name="single_phase_surcharge"/>
                            <field name="three_phase_surcharge"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_calculator_setting" model="ir.actions.act_window">
        <field name="name">Calculator Settings</field>
        <field name="res_model">calculator.setting</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'form_view_initial_mode': 'edit'}</field>
    </record>

    <record id="action_calculator_setting_server" model="ir.actions.server">
        <field name="name">Calculator Settings</field>
        <field name="model_id" ref="model_calculator_setting"/>
        <field name="state">code</field>
        <field name="code">action = env.ref('union_energy_calculator.action_calculator_setting').read()[0]
settings = env['calculator.setting'].get_settings()
action['res_id'] = settings.id
action['views'] = [(env.ref('union_energy_calculator.view_calculator_setting_form').id, 'form')]
</field>
    </record>
</odoo>
